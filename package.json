{
  "name": "sokol-87",
  "version": "1.0.0",
  "description": "СОКОЛ-87 — тактический авиасимулятор (offline HTML game, упакованный в APK через Capacitor)",
  "author": "Celesteal",
  "license": "MIT",
  "private": true,
  "scripts": {
    "init": "cap init \"СОКОЛ-87\" com.celesteal.sokol87 --web-dir=www",
    "add:android": "cap add android",
    "sync": "cap sync android",
    "copy": "cap copy android",
    "open": "cap open android",
    "build:debug": "cd android && ./gradlew assembleDebug",
    "build:release": "cd android && ./gradlew assembleRelease",
    "apk:debug": "npm run sync && npm run build:debug",
    "apk:release": "npm run sync && npm run build:release"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  }
}
